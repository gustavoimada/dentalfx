	<query language="SQL"><![CDATA[SELECT
  CURRENT_DATE AS data, 
  '08:00' AS horario,        
  'Nome do Paciente' AS pac_nome,
  'Nome do Dentista' AS dentista,  
  'Cidade do Paciente' AS pac_cidade 
FROM
  consulta
LIMIT 1]]></query>
