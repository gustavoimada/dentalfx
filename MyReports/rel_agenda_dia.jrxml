	<query language="SQL"><![CDATA[SELECT
  8 AS horario,                     
  'Nome do Paciente' AS pac_nome,
  'Nome do Dentista' AS den_nome,
  'Status do Atendimento' AS status 
FROM
  consulta
LIMIT 1]]></query>
