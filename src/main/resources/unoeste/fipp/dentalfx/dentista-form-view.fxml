<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="276.0" prefWidth="628.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="unoeste.fipp.dentalfx.DentistaFormController">
   <children>
      <VBox prefHeight="219.0" prefWidth="628.0" VBox.vgrow="ALWAYS">
         <children>
            <Label text="ID:">
               <padding>
                  <Insets top="10.0" />
               </padding>
            </Label>
            <TextField fx:id="tfID" disable="true" editable="false" style="-fx-background-radius: 7; -fx-border-radius: 7;">
               <font>
                  <Font size="14.0" />
               </font>
            </TextField>
            <Label layoutX="10.0" layoutY="10.0" text="Nome:">
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
            </Label>
            <TextField fx:id="tfNome" layoutX="10.0" layoutY="27.0" style="-fx-background-radius: 7; -fx-border-radius: 7;">
               <font>
                  <Font size="14.0" />
               </font>
            </TextField>
            <Label layoutX="20.0" layoutY="92.0" text="CRO:">
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
            </Label>
            <TextField fx:id="tfCro" layoutX="20.0" layoutY="109.0" style="-fx-background-radius: 7; -fx-border-radius: 7;">
               <font>
                  <Font size="14.0" />
               </font>
               <VBox.margin>
                  <Insets />
               </VBox.margin>
            </TextField>
            <Label layoutX="20.0" layoutY="134.0" text="TELEFONE:">
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
            </Label>
            <TextField fx:id="tfFone" layoutX="20.0" layoutY="151.0" style="-fx-background-radius: 7; -fx-border-radius: 7;">
               <font>
                  <Font size="14.0" />
               </font>
               <VBox.margin>
                  <Insets />
               </VBox.margin>
            </TextField>
            <Label layoutX="20.0" layoutY="176.0" text="EMAIL:">
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
            </Label>
            <TextField fx:id="tfEmail" layoutX="20.0" layoutY="193.0" style="-fx-background-radius: 7; -fx-border-radius: 7;">
               <font>
                  <Font size="14.0" />
               </font>
               <VBox.margin>
                  <Insets />
               </VBox.margin>
            </TextField>
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </VBox>
      <HBox alignment="CENTER" maxHeight="50.0" minHeight="50.0" prefHeight="50.0" prefWidth="628.0" spacing="32.0" style="-fx-background-color: #e7ecef; -fx-background-radius: 10 10 0 0;">
         <children>
            <Button mnemonicParsing="false" onAction="#onConfirmar" prefHeight="28.0" prefWidth="120.0" style="-fx-background-radius: 10; -fx-border-radius: 10;" text="Confirmar" />
            <Button mnemonicParsing="false" onAction="#onCancelar" prefHeight="28.0" prefWidth="120.0" style="-fx-border-radius: 10; -fx-background-radius: 10;" text="Cancelar" />
         </children>
      </HBox>
   </children>
</VBox>
