<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="400.0" prefWidth="367.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="unoeste.fipp.dentalfx.MenuController">
    <bottom>
        <HBox alignment="CENTER" prefHeight="33.0" prefWidth="367.0" style="-fx-background-color: #0a0a0a;" BorderPane.alignment="CENTER" />
    </bottom>
    <center>
        <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0" BorderPane.alignment="CENTER">
            <children>
                <Label fx:id="idTextoSobre" alignment="CENTER" prefHeight="180.0" prefWidth="367.0" text="DentalFX é um sistema desenvolvido para auxiliar o gerenciamento de clínicas odontológicas, oferecendo uma forma simples, rápida e organizada de administrar pacientes, dentistas e consultas.
Com ele, é possível cadastrar informações, agendar atendimentos, registrar relatos e acompanhar o status de cada consulta em tempo real.

O objetivo do aplicativo é facilitar o dia a dia da clínica, trazendo mais controle, segurança e praticidade para toda a equipe." textAlignment="CENTER" wrapText="true" />
                <Label text="Desenvolvedores: Luiz Carlos, Gustavo Imada e Raul Teixeira" textAlignment="CENTER" />
            </children>
        </VBox>
    </center>
</BorderPane>
