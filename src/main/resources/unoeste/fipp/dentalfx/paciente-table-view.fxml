<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ContextMenu?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="399.0" prefWidth="742.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="unoeste.fipp.dentalfx.PacienteTableController">
    <children>
        <HBox alignment="CENTER" maxHeight="50.0" minHeight="50.0" prefHeight="50.0" prefWidth="742.0" spacing="48.0" style="-fx-background-color: #e7ecef;">
            <children>
                <TextField fx:id="tfFiltro" onKeyTyped="#onFiltrar" prefHeight="25.0" prefWidth="589.0" promptText="Informe o paciente" style="-fx-background-radius: 7; -fx-border-radius: 7;" />
                <Button mnemonicParsing="false" onAction="#onNovoPaciente" style="-fx-background-radius: 50; -fx-border-radius: 50;" text="+" />
            </children>
        </HBox>
        <TableView fx:id="tableView" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colID" maxWidth="75.0" minWidth="75.0" prefWidth="75.0" text="ID" />
                <TableColumn fx:id="colNome" maxWidth="500.0" prefWidth="350.0" text="NOME" />
                <TableColumn fx:id="colCidade" maxWidth="200.0" minWidth="120.0" prefWidth="200.0" text="CIDADE" />
            <TableColumn fx:id="colFone" maxWidth="120.0" minWidth="120.0" prefWidth="120.0" text="FONE" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
         <contextMenu>
            <ContextMenu>
                <items>
                    <MenuItem mnemonicParsing="false" onAction="#onAlterar" text="Alterar" />
                    <MenuItem mnemonicParsing="false" onAction="#onApagar" text="Apagar" />
                    <MenuItem mnemonicParsing="false" onAction="#onGerarFicha" text="Gerar Ficha" />
                </items>
            </ContextMenu>
         </contextMenu>
        </TableView>
        <HBox alignment="CENTER" layoutX="10.0" layoutY="10.0" maxHeight="50.0" minHeight="50.0" prefHeight="50.0" prefWidth="742.0" style="-fx-background-color: #e7ecef; -fx-background-radius: 10 10 0 0;">
            <children>
                <Button mnemonicParsing="false" onAction="#btFechar" prefHeight="25.0" prefWidth="120.0" style="-fx-background-radius: 10; -fx-border-radius: 10;" text="Fechar" />
            </children>
        </HBox>
    </children>
</VBox>
